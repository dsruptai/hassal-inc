{
  "builds": [
    { "src": "public/**", "use": "@vercel/static" },
    { "src": "api/chat.py", "use": "@vercel/python", "config": { "maxDuration": 120 } },
    { "src": "api/cron.py", "use": "@vercel/python", "config": { "maxDuration": 120 } }
  ],
  "routes": [
    { "src": "/api/chat", "dest": "/api/chat.py" },
    { "src": "/api/cron", "dest": "/api/cron.py" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ],
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 5 * * *"
    }
  ]
}
